{
    "height": 30,
    "spacing": 4,
    "modules-left": ["sway/workspaces", "network#speed", "sway/mode", "sway/scratchpad"],
    "modules-center": ["sway/window"],
    "modules-right": ["idle_inhibitor", "wireplumber", "network", "cpu", "memory", "temperature", "backlight", "battery", "clock", "tray"],
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", ""],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "tray": {
        "spacing": 10
    },
    "cpu": {
        "format": " CPU {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": " RAM {percentage}%",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G used"
    },
    "temperature": {
        "format": " {temperatureC}°C",
        "critical-threshold": 80,
        "format-critical": " {temperatureC}°C"
    },
    "backlight": {
        "format": "☀ Bright {percent}%"
    },
    "clock": {
        "format": " {:%Y-%m-%d %H:%M:%S}",
        "interval": 1
    },
    "battery": {
        "format": "{icon} Bat {capacity}%",
        "format-charging": " Charging {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },
    "network": {
        "format-wifi": " {essid} ({signalStrength}%)",
        "format-ethernet": " {ipaddr}/{cidr}",
        "format-disconnected": "⚠ Disconnected"
    },
    "network#speed": {
        "interval": 1,
        "format": "↑{bandwidthUpBytes} ↓{bandwidthDownBytes}",
        "format-disconnected": "No network"
    },
    "wireplumber": {
        "format": "{icon} Vol {volume}%",
        "format-muted": " Muted {volume}%",
        "format-icons": ["", "", ""],
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    }
}
