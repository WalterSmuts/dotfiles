{
    "height": 30,
    "spacing": 4,
    "modules-left": ["sway/workspaces", "custom/mail", "network#speed", "sway/mode", "sway/scratchpad"],
    "modules-center": ["sway/window"],
    "modules-right": ["idle_inhibitor", "wireplumber", "network", "cpu", "memory", "temperature", "backlight", "battery", "clock", "tray", "custom/notification"],
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", ""],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "tray": {
        "spacing": 10
    },
    "cpu": {
        "format": " CPU {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": " RAM {percentage}%",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G used"
    },
    "temperature": {
        "format": " {temperatureC}°C",
        "critical-threshold": 80,
        "format-critical": " {temperatureC}°C"
    },
    "backlight": {
        "format": "☀ Bright {percent}%"
    },
    "clock": {
        "format": " {:%Y-%m-%d %H:%M:%S}",
        "interval": 1
    },
    "battery": {
        "format": "{icon} Bat {capacity}%",
        "format-charging": " Charging {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },
    "network": {
        "format-wifi": " {essid} ({signalStrength}%)",
        "format-ethernet": " {ipaddr}/{cidr}",
        "format-disconnected": "⚠ Disconnected"
    },
    "network#speed": {
        "interval": 1,
        "format": "↑{bandwidthUpBytes} ↓{bandwidthDownBytes}",
        "format-disconnected": "No network"
    },
    "custom/mail": {
        "exec": "~/.local/bin/mail-status",
        "return-type": "json",
        "interval": 30,
        "on-click": "swaymsg exec 'foot neomutt'"
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon} {}",
        "format-icons": {
            "notification": "<span foreground='red'><sup></sup></span>",
            "none": "",
            "dnd-notification": "<span foreground='red'><sup></sup></span>",
            "dnd-none": "",
            "inhibited-notification": "<span foreground='red'><sup></sup></span>",
            "inhibited-none": "",
            "dnd-inhibited-notification": "<span foreground='red'><sup></sup></span>",
            "dnd-inhibited-none": ""
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "wireplumber": {
        "format": "{icon} Vol {volume}%",
        "format-muted": " Muted {volume}%",
        "format-icons": ["", "", ""],
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    }
}
