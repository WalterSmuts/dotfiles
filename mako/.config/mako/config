# Mako notification configuration

# Appearance
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#89b4fa
border-size=2
border-radius=10
padding=15
margin=10

# Font
font=Inter 11

# Position and size
anchor=top-right
width=350
height=100

# Behavior
default-timeout=5000
ignore-timeout=1

# Icons
icons=1
max-icon-size=48
icon-location=left

# Grouping
group-by=app-name
max-visible=5

# Progress bar
progress-color=over #313244

# Urgency levels
[urgency=low]
border-color=#a6e3a1
default-timeout=3000

[urgency=normal]
border-color=#89b4fa
default-timeout=5000

[urgency=critical]
border-color=#f38ba8
default-timeout=0
text-color=#f38ba8

[mode=do-not-disturb]
invisible=1
