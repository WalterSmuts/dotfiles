# vim: filetype=neomuttrc
# neomutt config — read-only Amazon mail via mbsync (mutt-wizard inspired)

# ── Account ──────────────────────────────────────────────────────────
set realname = "wssmts"
set from = "wssmts@amazon.com"
set folder = "~/.local/share/mail/amazon"
set spoolfile = "+INBOX"
set mbox_type = Maildir
set mailcap_path = "~/.config/mutt/mailcap"

# ── Behavior ─────────────────────────────────────────────────────────
set sort = reverse-date
set date_format = "%y/%m/%d %I:%M%p"
set index_format = "%2C %Z %?X?A& ? %D %-15.15F %s (%-4.4c)"
set sleep_time = 0
set markers = no
set mark_old = no
set wait_key = no
set fast_reply
set forward_format = "Fwd: %s"
set forward_quote
set include
set reverse_name
set rfc2047_parameters = yes
set mail_check = 60
set mail_check_stats
set charset = "utf-8"
set send_charset = "us-ascii:utf-8"
set pager_stop
set pager_index_lines = 0
set pager_context = 3
set tilde

# HTML mail
set mime_type_query_command = "file --mime-type -b %s"
auto_view text/html
alternative_order text/plain text/enriched text/html

# ── Sidebar ──────────────────────────────────────────────────────────
set sidebar_visible = yes
set sidebar_width = 24
set sidebar_short_path = yes
set sidebar_next_new_wrap = yes
set sidebar_format = "%D%?F? [%F]?%* %?N?%N/?%?S?%S?"

# ── Vim-like keybindings ─────────────────────────────────────────────
# Clear defaults
bind index,pager i noop
bind index,pager g noop
bind index \Cf noop
bind index,pager M noop
bind index,pager C noop

# Index navigation
bind index j next-entry
bind index k previous-entry
bind index gg first-entry
bind index G last-entry
bind index l display-message
bind index h noop
bind index,pager d half-down
bind index,pager u half-up
bind index L limit
bind index \031 previous-undeleted
bind index \005 next-undeleted

# Pager navigation
bind pager j next-line
bind pager k previous-line
bind pager gg top
bind pager G bottom
bind pager h exit
bind pager l view-attachments
bind pager \031 previous-line
bind pager \005 next-line

# Attachments
bind attach l view-mailcap
bind attach h exit

# Sidebar
bind index,pager \Ck sidebar-prev
bind index,pager \Cj sidebar-next
bind index,pager \Co sidebar-open
bind index,pager \Cp sidebar-prev-new
bind index,pager \Cn sidebar-next-new
bind index,pager B sidebar-toggle-visible

# Folder navigation
mailboxes =INBOX =Archive ="Code Reviews" =Issues =Meetings
macro index,pager gi "<change-folder>=INBOX<enter>" "go to inbox"
macro index,pager ga "<change-folder>=Archive<enter>" "go to archive"
macro index,pager gr "<change-folder>=Code Reviews<enter>" "go to code reviews"
macro index,pager gI "<change-folder>=Issues<enter>" "go to issues"
macro index,pager gm "<change-folder>=Meetings<enter>" "go to meetings"

# Sync mail
macro index O "<shell-escape>mailsync<enter>" "run mbsync to sync mail"
macro index \Cr "T~U<enter><tag-prefix><clear-flag>N<untag-pattern>.<enter>" "mark all as read"
macro index A "<limit>all\n" "show all messages (undo limit)"

# Open URLs (if urlscan installed)
macro index,pager \Cu "<pipe-message>urlscan<enter>" "open URLs with urlscan"

# Editor
bind editor <Tab> complete-query

# ── Colors (mutt-wizard / gruvbox inspired) ──────────────────────────
# Index
color index yellow default '.*'
color index_author red default '.*'
color index_number blue default
color index_subject cyan default '.*'
color index brightyellow black "~N"
color index_author brightred black "~N"
color index_subject brightcyan black "~N"
color index brightyellow blue "~T"
color index_author brightred blue "~T"
color index_subject brightcyan blue "~T"
color index brightgreen default "~F"
color index_author brightgreen default "~F"
color index_subject brightgreen default "~F"

# Chrome
color normal default default
color indicator brightblack white
color error red default
color tilde black default
color message cyan default
color markers red white
color attachment white default
color search brightmagenta default
color status brightyellow black
color hdrdefault brightgreen default

# Sidebar
color sidebar_highlight red default
color sidebar_divider brightblack black
color sidebar_flagged red black
color sidebar_new green black

# Headers
color header brightmagenta default "^From"
color header brightcyan default "^Subject"
color header brightwhite default "^(CC|BCC)"
color header blue default ".*"

# Quoted text
color quoted green default
color quoted1 blue default
color quoted2 cyan default
color quoted3 yellow default
color quoted4 red default

# Body highlights
color body brightred default "[-a-z_0-9.+]+@[-a-z_0-9.]+"
color body brightblue default "(https?|ftp)://[^ \"\t\r\n<>]+"
color body brightblue default "^# .*"
color body brightcyan default "^## .*"
color body brightgreen default "^### .*"
color body yellow default "^( )*(-|\\*) .*"

# Strstripes
color signature brightgreen default
color bold black default
color underline black default
mono bold bold
mono underline underline
mono indicator reverse
mono error bold
